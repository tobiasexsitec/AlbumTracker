@page "/about"
@using AlbumTracker.Components

<PageTitle>About - AlbumTracker</PageTitle>

<div class="about-page">
    <div class="about-header">
        <h1>🎵 About AlbumTracker</h1>
        <p class="lead">Your personal music companion for tracking listening habits and organizing your album collection.</p>
    </div>

    <div class="about-content">
        <h2>Features</h2>
        <FeaturesSection />

        <div class="about-section mt-5">
            <h2>How It Works</h2>
            <div class="how-it-works">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h3>Sign In</h3>
                    <p>Create an account using your Google login to get started</p>
                </div>
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h3>Search Albums</h3>
                    <p>Find your favorite albums from our extensive music database</p>
                </div>
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h3>Organize & Track</h3>
                    <p>Create lists, rate albums, and log your listening history</p>
                </div>
            </div>
        </div>

        <div class="about-section mt-5">
            <h2>Why AlbumTracker?</h2>
            <p>AlbumTracker was built for music enthusiasts who want a simple, elegant way to keep track of their album collection and listening habits. Whether you're a casual listener or a dedicated audiophile, AlbumTracker helps you:</p>
            <ul>
                <li>Maintain a comprehensive catalog of albums you own or want to explore</li>
                <li>Track your listening patterns and see which albums you play most</li>
                <li>Rate and review albums to remember your thoughts</li>
                <li>Access your collection from any device with cloud sync</li>
                <li>Discover albums through search and keep a wish list</li>
            </ul>
        </div>
    </div>

    <FeatureRequestSection />
</div>
