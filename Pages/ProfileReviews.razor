@page "/profile/reviews"
@using Microsoft.AspNetCore.Components.Authorization
@inject IAlbumReviewService ReviewService
@inject IAlbumInfoService AlbumInfoService
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<PageTitle>AlbumTracker - My Reviews</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="profile-ratings-page">
            <div class="page-header">
                <a href="profile" class="back-link">← Profile</a>
                <h1>My Reviews</h1>
            </div>

            @if (_loading)
            {
                <p>Loading...</p>
            }
            else if (_reviewItems.Count == 0)
            {
                <p class="text-muted">You haven't reviewed any albums yet.</p>
            }
            else
            {
                <div class="rating-list">
                    @foreach (var item in _reviewItems)
                    {
                        <div class="rating-list-item" @onclick="() => SelectAlbum(item.AlbumInfo)">
                            <AlbumCoverImage CssClass="rating-item-cover" Src="@item.AlbumInfo?.CoverImageUrl" Alt="@(item.AlbumInfo?.Name ?? item.Review.AlbumId)" />
                            <div class="rating-item-info">
                                <span class="rating-item-title">@(item.AlbumInfo?.Name ?? item.Review.AlbumId)</span>
                                <span class="rating-item-artist">@(item.AlbumInfo?.Artist ?? "")</span>
                                <span class="review-item-comment">@Truncate(item.Review.Comment, 80)</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <AlbumDetailPanel Album="_selectedAlbum" OnClose="CloseDetail" />
    </Authorized>
    <NotAuthorized>
        <p>Please sign in to view your reviews.</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<ReviewItem> _reviewItems = [];
    private bool _loading = true;
    private Album? _selectedAlbum;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            await LoadReviewsAsync();
        }

        _loading = false;
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        var authState = await task;
        if (authState.User.Identity?.IsAuthenticated == true && _reviewItems.Count == 0)
        {
            _loading = true;
            await InvokeAsync(StateHasChanged);

            await LoadReviewsAsync();

            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadReviewsAsync()
    {
        var reviews = await ReviewService.GetAllReviewsAsync();
        var sorted = reviews.OrderByDescending(r => r.UpdatedAt).ToList();

        var albumInfoLookup = await AlbumInfoService.GetAllAlbumInfoAsync();

        foreach (var review in sorted)
        {
            albumInfoLookup.TryGetValue(review.AlbumId, out var albumInfo);
            _reviewItems.Add(new ReviewItem(review, albumInfo));
        }
    }

    private void SelectAlbum(AlbumInfo? info)
    {
        _selectedAlbum = info is not null
            ? new Album { Id = info.Id, Name = info.Name, Artist = info.Artist, CoverImageUrl = info.CoverImageUrl, SpotifyAlbumId = info.Id }
            : null;
    }

    private void CloseDetail() => _selectedAlbum = null;

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
    }

    private static string Truncate(string text, int maxLength)
        => text.Length <= maxLength ? text : string.Concat(text.AsSpan(0, maxLength), "…");

    private record ReviewItem(AlbumReview Review, AlbumInfo? AlbumInfo);
}
