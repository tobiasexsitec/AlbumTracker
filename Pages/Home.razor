@page "/"
@using AlbumTracker.Models
@using AlbumTracker.Services
@using AlbumTracker.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@inject IAlbumListService ListService
@inject IListenHistoryService HistoryService
@inject FirebaseAuthStateProvider AuthProvider
@inject IJSRuntime JS

<PageTitle>AlbumTracker - Home</PageTitle>

<AuthorizeView>
    <NotAuthorized>
        <div class="welcome-hero">
            <h1>🎵 Welcome to AlbumTracker</h1>
            <p>Track your music listening habits, organize albums into custom lists, rate them, and keep a detailed listen history.</p>
            <p>To get started, sign in with your Google account.</p>
            <button class="btn btn-primary btn-lg" @onclick="SignIn">Sign in with Google</button>
        </div>
    </NotAuthorized>
    <Authorized Context="auth">
        <AlbumSearchBar OnAlbumSelected="SelectAlbum" OnSearchResults="HandleSearchResults" OnSearchPerformed="HandleSearchPerformed" />

        @if (_searchResults is not null)
        {
            @if (_searchResults.Count == 0)
            {
                <p class="mt-3">No albums found for "<strong>@_lastSearchQuery</strong>".</p>
            }
            else
            {
                <h2 class="mt-3">Search Results</h2>
                <div class="album-grid mt-3">
                    @foreach (var album in _searchResults)
                    {
                        <AlbumCard Album="album" Clicked="() => SelectAlbum(album)" />
                    }
                </div>
            }
        }

        <h2>🎵 Latest Played Albums</h2>

        @if (_loading)
        {
            <div class="auth-spinner"></div>
        }
        else if (_latestPlayedAlbums is null || _latestPlayedAlbums.Count == 0)
        {
            <p>No albums in your listening history yet. <a href="search">Search for albums</a> to get started!</p>
        }
        else
        {
            <div class="album-grid">
                @foreach (var album in _latestPlayedAlbums)
                {
                    <AlbumCard Album="album" Clicked="() => SelectAlbum(album)" />
                }
            </div>
        }

        <AlbumDetailPanel Album="_selectedAlbum" OnClose="CloseDetail" />
    </Authorized>
</AuthorizeView>

@code {
    private const int MobileBreakpoint = 768;

    private List<Album>? _latestPlayedAlbums;
    private bool _loading = true;
    private bool _dataLoaded;
    private Album? _selectedAlbum;

    private string _lastSearchQuery = string.Empty;
    private List<Album>? _searchResults;

    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_dataLoaded) return;

        var state = await AuthState;
        if (state.User.Identity?.IsAuthenticated == true)
        {
            _dataLoaded = true;
            await LoadLatestPlayedAlbumsAsync();
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadLatestPlayedAlbumsAsync()
    {
        var histories = await HistoryService.GetAllHistoriesAsync();

        if (histories.Count == 0)
        {
            _latestPlayedAlbums = [];
            return;
        }

        var allLists = await ListService.GetAllListsAsync();
        var allAlbums = allLists
            .SelectMany(list => list.Entries.Select(e => e.Album))
            .GroupBy(a => a.Id)
            .Select(g => g.First())
            .ToDictionary(a => a.Id);

        var takeCount = await JS.InvokeAsync<bool>("eval", $"window.innerWidth < {MobileBreakpoint}") ? 10 : 21;

        var albumsWithHistory = histories
            .Where(h => allAlbums.ContainsKey(h.AlbumId))
            .Select(h => new { Album = allAlbums[h.AlbumId], LastPlayed = h.LatestListenDate })
            .Where(x => x.LastPlayed.HasValue)
            .OrderByDescending(x => x.LastPlayed)
            .Take(takeCount)
            .Select(x => x.Album)
            .ToList();

        _latestPlayedAlbums = albumsWithHistory;
    }

    private void SelectAlbum(Album album) => _selectedAlbum = album;

    private void CloseDetail() => _selectedAlbum = null;

    private void HandleSearchPerformed(string query) => _lastSearchQuery = query;

    private void HandleSearchResults(List<Album> results) => _searchResults = results;

    private async Task SignIn() => await AuthProvider.SignInWithGoogleAsync();
}
