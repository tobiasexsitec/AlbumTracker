@page "/profile/ratings"
@using Microsoft.AspNetCore.Components.Authorization
@inject IAlbumRatingService RatingService
@inject IAlbumInfoService AlbumInfoService

<PageTitle>AlbumTracker - My Ratings</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="profile-ratings-page">
            <div class="page-header">
                <a href="profile" class="back-link">← Profile</a>
                <h1>My Ratings</h1>
            </div>

            @if (_loading)
            {
                <p>Loading...</p>
            }
            else if (_ratingItems.Count == 0)
            {
                <p class="text-muted">You haven't rated any albums yet.</p>
            }
            else
            {
                <div class="rating-list">
                    @foreach (var item in _ratingItems)
                    {
                        <div class="rating-list-item" @onclick="() => SelectAlbum(item.AlbumInfo)">
                            <AlbumCoverImage CssClass="rating-item-cover" Src="@item.AlbumInfo?.CoverImageUrl" Alt="@(item.AlbumInfo?.Name ?? item.Rating.AlbumId)" />
                            <div class="rating-item-info">
                                <span class="rating-item-title">@(item.AlbumInfo?.Name ?? item.Rating.AlbumId)</span>
                                <span class="rating-item-artist">@(item.AlbumInfo?.Artist ?? "")</span>
                            </div>
                            <div class="rating-item-stars">
                                <StarRating AlbumId="@item.Rating.AlbumId" InitialRating="@item.Rating.Rating" ReadOnly="true" />
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <AlbumDetailPanel Album="_selectedAlbum" OnClose="CloseDetail" />
    </Authorized>
    <NotAuthorized>
        <p>Please sign in to view your ratings.</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<RatingItem> _ratingItems = [];
    private bool _loading = true;
    private Album? _selectedAlbum;

    protected override async Task OnInitializedAsync()
    {
        var ratings = await RatingService.GetAllRatingsAsync();
        var sorted = ratings.OrderByDescending(r => r.RatedAt).ToList();

        var albumInfoLookup = await AlbumInfoService.GetAllAlbumInfoAsync();

        foreach (var rating in sorted)
        {
            albumInfoLookup.TryGetValue(rating.AlbumId, out var albumInfo);
            _ratingItems.Add(new RatingItem(rating, albumInfo));
        }

        _loading = false;
    }

    private void SelectAlbum(AlbumInfo? info)
    {
        _selectedAlbum = info is not null
            ? new Album { Id = info.Id, Name = info.Name, Artist = info.Artist, CoverImageUrl = info.CoverImageUrl, SpotifyAlbumId = info.Id }
            : null;
    }

    private void CloseDetail() => _selectedAlbum = null;

    private record RatingItem(AlbumRating Rating, AlbumInfo? AlbumInfo);
}
