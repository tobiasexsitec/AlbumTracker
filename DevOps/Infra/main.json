{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "languageVersion": "2.0",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "1260325902604983887"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "swedencentral",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "appName": {
      "type": "string",
      "defaultValue": "albumtracker",
      "metadata": {
        "description": "Base name used for generating resource names"
      }
    },
    "spotifyClientId": {
      "type": "securestring",
      "metadata": {
        "description": "Spotify API Client ID"
      }
    },
    "spotifyClientSecret": {
      "type": "securestring",
      "metadata": {
        "description": "Spotify API Client Secret"
      }
    }
  },
  "variables": {
    "resourceGroupName": "[format('rg-{0}', parameters('appName'))]"
  },
  "resources": {
    "rg": {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2024-03-01",
      "name": "[variables('resourceGroupName')]",
      "location": "[parameters('location')]"
    },
    "resources": {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[format('resources-{0}', uniqueString('resources', deployment().name))]",
      "resourceGroup": "[variables('resourceGroupName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "appName": {
            "value": "[parameters('appName')]"
          },
          "spotifyClientId": {
            "value": "[parameters('spotifyClientId')]"
          },
          "spotifyClientSecret": {
            "value": "[parameters('spotifyClientSecret')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "14958432126339841674"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for all resources"
              }
            },
            "appName": {
              "type": "string",
              "metadata": {
                "description": "Base name used for generating resource names"
              }
            },
            "spotifyClientId": {
              "type": "securestring",
              "metadata": {
                "description": "Spotify API Client ID"
              }
            },
            "spotifyClientSecret": {
              "type": "securestring",
              "metadata": {
                "description": "Spotify API Client Secret"
              }
            }
          },
          "variables": {
            "uniqueSuffix": "[uniqueString(resourceGroup().id)]"
          },
          "resources": [
            {
              "type": "Microsoft.OperationalInsights/workspaces",
              "apiVersion": "2023-09-01",
              "name": "[format('log-{0}', parameters('appName'))]",
              "location": "[parameters('location')]",
              "properties": {
                "sku": {
                  "name": "PerGB2018"
                },
                "retentionInDays": 30
              }
            },
            {
              "type": "Microsoft.Insights/components",
              "apiVersion": "2020-02-02",
              "name": "[format('appi-{0}', parameters('appName'))]",
              "location": "[parameters('location')]",
              "kind": "web",
              "properties": {
                "Application_Type": "web",
                "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', parameters('appName')))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', parameters('appName')))]"
              ]
            },
            {
              "type": "Microsoft.Storage/storageAccounts",
              "apiVersion": "2023-05-01",
              "name": "[format('st{0}{1}', parameters('appName'), variables('uniqueSuffix'))]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "Standard_LRS"
              },
              "kind": "StorageV2",
              "properties": {
                "supportsHttpsTrafficOnly": true,
                "minimumTlsVersion": "TLS1_2"
              }
            },
            {
              "type": "Microsoft.Web/serverfarms",
              "apiVersion": "2024-04-01",
              "name": "[format('asp-{0}', parameters('appName'))]",
              "location": "[parameters('location')]",
              "kind": "linux",
              "sku": {
                "name": "Y1",
                "tier": "Dynamic"
              },
              "properties": {
                "reserved": true
              }
            },
            {
              "type": "Microsoft.Web/sites",
              "apiVersion": "2024-04-01",
              "name": "[format('func-{0}-{1}', parameters('appName'), variables('uniqueSuffix'))]",
              "location": "[parameters('location')]",
              "kind": "functionapp,linux",
              "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', format('asp-{0}', parameters('appName')))]",
                "httpsOnly": true,
                "siteConfig": {
                  "linuxFxVersion": "DOTNET-ISOLATED|8.0",
                  "appSettings": [
                    {
                      "name": "AzureWebJobsStorage",
                      "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', format('st{0}{1}', parameters('appName'), variables('uniqueSuffix')), environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', format('st{0}{1}', parameters('appName'), variables('uniqueSuffix'))), '2023-05-01').keys[0].value)]"
                    },
                    {
                      "name": "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING",
                      "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', format('st{0}{1}', parameters('appName'), variables('uniqueSuffix')), environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', format('st{0}{1}', parameters('appName'), variables('uniqueSuffix'))), '2023-05-01').keys[0].value)]"
                    },
                    {
                      "name": "WEBSITE_CONTENTSHARE",
                      "value": "[toLower(format('func-{0}', parameters('appName')))]"
                    },
                    {
                      "name": "FUNCTIONS_EXTENSION_VERSION",
                      "value": "~4"
                    },
                    {
                      "name": "FUNCTIONS_WORKER_RUNTIME",
                      "value": "dotnet-isolated"
                    },
                    {
                      "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
                      "value": "[reference(resourceId('Microsoft.Insights/components', format('appi-{0}', parameters('appName'))), '2020-02-02').InstrumentationKey]"
                    },
                    {
                      "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                      "value": "[reference(resourceId('Microsoft.Insights/components', format('appi-{0}', parameters('appName'))), '2020-02-02').ConnectionString]"
                    },
                    {
                      "name": "Spotify__ClientId",
                      "value": "[parameters('spotifyClientId')]"
                    },
                    {
                      "name": "Spotify__ClientSecret",
                      "value": "[parameters('spotifyClientSecret')]"
                    }
                  ],
                  "cors": {
                    "allowedOrigins": [
                      "https://tobiasexsitec.github.io"
                    ]
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Insights/components', format('appi-{0}', parameters('appName')))]",
                "[resourceId('Microsoft.Web/serverfarms', format('asp-{0}', parameters('appName')))]",
                "[resourceId('Microsoft.Storage/storageAccounts', format('st{0}{1}', parameters('appName'), variables('uniqueSuffix')))]"
              ]
            }
          ],
          "outputs": {
            "functionAppName": {
              "type": "string",
              "value": "[format('func-{0}-{1}', parameters('appName'), variables('uniqueSuffix'))]"
            },
            "functionAppHostname": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Web/sites', format('func-{0}-{1}', parameters('appName'), variables('uniqueSuffix'))), '2024-04-01').defaultHostName]"
            }
          }
        }
      },
      "dependsOn": [
        "rg"
      ]
    }
  },
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[reference('resources').outputs.functionAppName.value]"
    },
    "functionAppHostname": {
      "type": "string",
      "value": "[reference('resources').outputs.functionAppHostname.value]"
    }
  }
}